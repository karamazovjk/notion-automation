# Copie este arquivo para .env e preencha com seus dados
# NUNCA commite o arquivo .env no GitHub

# Token de integração do Notion
# Onde encontrar: notion.so/my-integrations → seu app → "Internal Integration Secret"
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do database de tarefas
# Onde encontrar: abra o database no Notion → copie o ID da URL
# URL: notion.so/seu-workspace/ESTE-TRECHO-É-O-ID?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
